{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/allianz-engagement-survey/refs/heads/main/json-structure/engagement-survey-question-score-structure.json",
  "description": "Score summary for a single survey question",
  "properties": {
    "question_id": {
      "type": "string",
      "description": "Question identifier",
      "example": "q-001"
    },
    "question": {
      "type": "string",
      "description": "The survey question text",
      "example": "I am proud to work for Allianz"
    },
    "score": {
      "type": "double",
      "description": "Average score on a 1-5 scale",
      "example": 4.2
    },
    "favorable": {
      "type": "double",
      "description": "Percentage of favorable responses (4-5 on Likert scale)",
      "example": 84.0
    }
  },
  "name": "QuestionScore"
}